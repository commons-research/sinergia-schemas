# More about KOS:  https://www.isko.org/cyclo
# A nice intro: https://solidproject.org/developers/

@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>   .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#>         .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#>             .
@prefix owl:     <http://www.w3.org/2002/07/owl#>                .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#>          .
@prefix foaf:    <http://xmlns.com/foaf/0.1/>                    .
@prefix wd:      <http://www.wikidata.org/entity/>               .
@prefix vann:    <http://purl.org/vocab/vann/>                   .
@prefix dcterms: <http://purl.org/dc/terms/>                     .
@prefix sdo: 	 <http://schema.org/>                            .
@prefix orcid:	 <http://orcid.org/>                             .
@prefix void:	 <http://rdfs.org/ns/void#>                      .
@prefix prov:    <http://www.w3.org/ns/prov#/>        .

# GraphDB is using the word "context" for is usually called "graph" in SPARQL
# The idea here is to prefix context/graph name with ctx:

@prefix jlw:     <https://www.sinergiawolfender.org/jlw/>        .

# -------------------------------------------------- #
# Semantic Versioning 2.0.0
# https://semver.org
# https://dgarijo.github.io/Widoco/doc/bestPractices/index-en.html
# -------------------------------------------------- #

jlw: a owl:Ontology ; 
	owl:versionIRI jlw:ontology_version\/0.1.0 ; 
	owl:versionInfo "0.1.0" ;
	dcterms:description "The RDF vocabulary describing concepts defined in the JLW dataset" ;
	dcterms:title "The JLW RDF vocabulary" ;
	dcterms:license <https://creativecommons.org/licenses/by-nc-sa/4.0/> ;
	dcterms:creator               jlw:Marco_Pagni                        ;
	dcterms:contributor	
		jlw:Florence_Mehl ,
		jlw:Frederic_Burdet ,
		jlw:Arnaud_Gaudry ;
	# dcterms:created xsd:dateTime 
	vann:preferredNamespaceUri "https://www.sinergiawolfender.org/jlw/"  ;
	vann:preferredNamespacePrefix "jlw"                                  .
	# foaf:logo
	# foaf:depiction schema here

# -------------------------------------------------- #
# PF-related classes and property
# see also PlantPartScheme in dataset.ttl
# -------------------------------------------------- #

jlw:PFCode a rdfs:Class ;
	rdfs:subClassOf jlw:LabSample ;
    rdfs:label "PF code" ;
    rdfs:comment "An entry code of the Pierre Fabre (PF) phytothèque. It corresponds to a single batch of plant collection. Different codes may refer to the same plant part and the same species, but in different batches i.e. different collection events." ;
	skos:example jlw:V100042 .

# -------------------------------------------------- #
# PF-related plant part scheme
# -------------------------------------------------- #

# jlw:PlantPartScheme a rdfs:Class ;
# 	rdfs:subClassOf skos:ConceptScheme ;
# 	rdfs:label "Plant part scheme"     ;
# 	rdfs:comment "A hierachical organization of plant parts adapted from the nomenclature found in the Pierre Fabre phytothèque. It is designed to capture most of the original annotations in a not-too-big hierarchy. A few rarely used or ambiguous designations were not taken into account (they are still visible in the comments of PfCode entries). Nota Bene: this scheme includes both plant organs sensu stricto (e.g. 'leaf' or 'flower') and practical categories with no botanical meaning (e.g. 'woody stem')" ;
# 	skos:hasTopConcept jlw:whole_plant .

jlw:PlantPart a rdfs:Class ;
    rdfs:label "Plant part" ;
    rdfs:comment "A plant part, adapted from the original nomenclature of the Pierre Fabre phytothèque. See jlw:PlantPartScheme for more details" .

jlw:is_from_plant_part a rdf:Property ; # FIXME: has_plant_part
  rdfs:label "is from plant part" ;
  rdfs:domain jlw:PFCode ; 
  rdfs:range  jlw:PlantPart .

jlw:is_part_of a rdf:Property ; # FIXME is_part_of_plant_part 
	rdfs:subPropertyOf skos:broaderMatch ;
	rdfs:label "is part of plant part" ;
	rdfs:domain jlw:PlantPart ; 
	rdfs:range  jlw:PlantPart .
	
# -------------------------------------------------- #
# Simplified taxonomy 
# -------------------------------------------------- #

jlw:Taxon a rdfs:Class ;
    rdfs:label "Taxon" ;
    rdfs:comment "This is a taxon in a simplified taxonomy derived from Open Tree of Life (OTT) 3.3, with a few modifications. This 'local' taxonomy is a balanced tree and therefore contains a few additionnal (i.e. 'unknown') nodes for the sake of balancing lineages. All PF codes are all placed at the 'species' rank. This also has required to remap some infra-specific assignment to the species rank. In addition a few 'Genus sp.' nodes were created for PF codes originally assignement at the genus rank" .
jlw:OttTaxon a rdfs:Class ;
	rdfs:subClassOf jlw:Taxon ;
	rdfs:label "Taxon with an OTT xref" .
jlw:UnknownTaxon a rdfs:Class ;
	rdfs:subClassOf jlw:Taxon ;
    rdfs:label "Placeholder taxon without OTT xref" .

jlw:has_parent_taxon a rdf:Property ;
	rdfs:subPropertyOf skos:broaderMatch  ;
	rdfs:label         "has parent taxon" ;
	rdfs:domain        jlw:Taxon          ;
	rdfs:range         jlw:Taxon          .

jlw:has_taxon a rdf:Property ;
	rdfs:label         "has taxon"       ;
	rdfs:domain        jlw:PFCode        ;
	rdfs:range         jlw:Taxon         .
jlw:has_exact_taxon a rdf:Property ;
	rdfs:subPropertyOf jlw:has_taxon, skos:exactMatch ;
	rdfs:label         "has exact taxon"              ;
	rdfs:domain        jlw:PFCode        ;
	rdfs:range         jlw:Taxon         .
jlw:has_broad_taxon a rdf:Property ;
	rdfs:subPropertyOf jlw:has_taxon, skos:broadMatch ;
	rdfs:label         "has broad taxon"              ;
	rdfs:domain        jlw:PFCode        ;
	rdfs:range         jlw:Taxon         .
jlw:has_narrow_taxon a rdf:Property ;
	rdfs:subPropertyOf jlw:has_taxon, skos:narrowMatch ;
	rdfs:label         "has narrow taxon"              ;
	rdfs:domain        jlw:PFCode        ;
	rdfs:range         jlw:Taxon         .

# -------------------------------------------------- #
# Chemical entity classes
# Nota Bene: Pubchem distinguishes compound from 
# substance, here we don"t
# -------------------------------------------------- #

jlw:ChemicalEntity  a rdfs:Class ;
    skos:exactMatch wd:Q11173       ;
    rdfs:label  "Chemical compound" ;
    rdfs:comment "A pure chemical substance consisting of one or more different chemical elements" .

jlw:has_InChI a rdf:Property  ;
	rdfs:label "has InChI"            ;
	rdfs:comment "has standard InChI" ;
	rdfs:domain jlw:ChemicalEntity    ;
	rdfs:range  xsd:string            .

jlw:has_InChIKey a rdf:Property  ;
	rdfs:label "has InChIKey"             ;
	rdfs:comment "has standard InChI key" ;
	rdfs:domain jlw:ChemicalEntity        ;
	rdfs:range  xsd:string                .

jlw:has_SMILES_iso a rdf:Property  ;
	rdfs:label "has isomeric SMILES"             ;
	rdfs:comment "has isomeric SMILES"           ;
	rdfs:domain jlw:ChemicalEntity               ;
	rdfs:range  xsd:string                       .

jlw:has_GNPS_Spectrum a rdf:Property  ;
	rdfs:label "has GNPS Spectrum"             ;
	rdfs:comment "has GNPS Spectrum"           ;
	rdfs:domain jlw:ChemicalEntity               ;
	rdfs:range  xsd:string                       .

jlw:has_chemical_entity a rdf:Property  ;
	rdfs:label "has chemical"          ;
	rdfs:comment "has chemical entity" ;
	rdfs:domain rdf:Resource           ;
	rdfs:range  jlw:ChemicalEntity     .

jlw:has_purified_compound a rdf:Property  ;
	rdfs:label "has purified compound"          ;
	rdfs:comment "has purified compound" ;
	rdfs:domain jlw:LabExtract           ; # TODO check if correct
	rdfs:range  jlw:LabPurifiedCompound     .

# -------------------------------------------------- #
# Hierarchical classification of lab samples
# -------------------------------------------------- #

jlw:LabProcess a rdf:Property  ; # FIXME: move it elsewhere
    rdfs:label "Lab process" ;
    rdfs:comment "A process carried in the lab that consists in extracting/fractionating a sample to produce another sample" .

jlw:has_purified_sample a rdf:Property ;
	rdfs:subPropertyOf jlw:LabProcess ;
	rdfs:label "has purified sample" ;
	rdfs:comment "has a derived sample in which a molecule is purified";
	rdfs:domain jlw:LabSample ;
	rdfs:range jlw:LabSample .

jlw:LabSample  a  rdfs:Class  ;
    rdfs:label   "Lab sample" ;
    rdfs:comment "Any physical sample in a specified amount. It could be a raw plant extract, a purified compound, a blank."  .

jlw:LabExtract a rdfs:Class      ;
	rdfs:subClassOf jlw:LabSample ;
    rdfs:label   "Lab extract"    ;
    rdfs:comment "A Physical sample resulting from an extraction procedure" .
	
jlw:LabFraction a rdfs:Class     ;
	rdfs:subClassOf jlw:LabSample ;
    rdfs:label   "Lab fraction"   ;
    rdfs:comment "A physical sample resulting from an fractionation procedure" .
jlw:LabControl a rdfs:Class     ;
    rdfs:subClassOf jlw:LabSample ;
    rdfs:label   "Lab control"   ;
    rdfs:comment "A physical sample used as a blank or QC standard in JLW" .
	
jlw:LabPurifiedCompound a rdfs:Class     ; 
    rdfs:subClassOf jlw:LabSample ;
    rdfs:label   "Lab purified compound"   ;
    rdfs:comment "Isolated from one or more samples" .

jlw:LabCompoundOtherOrigin a rdfs:Class     ; 
    rdfs:subClassOf jlw:LabSample ;
    rdfs:label   "Lab compond of other origin"   ;
    rdfs:comment "Purchased / synthesized" .

jlw:lab_ctrl_1 a jlw:LabControl ;    
    rdfs:label   "Lab control 1" ;
    rdfs:comment "A sample in well 01 used for a QC standard in JLW lab or for DMSO blank in CW lab" .
jlw:lab_ctrl_2 a jlw:LabControl ;        
    rdfs:label   "Lab control 2" ;
    rdfs:comment "A sample in well 12 used for blank in JLW lab or for tamoxifen control in CW lab" .

