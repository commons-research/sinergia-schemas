jlw:has_obtained_quantity a rdf:Property ;
    rdfs:label "Obtained quantity"       ;                 
    rdfs:comment "Obtained quantity [g]" ;           
    rdfs:domain jlw:LabSample            ;
	rdfs:range  xsd:double               .

jlw:has_process_yield a rdf:Property ;
    rdfs:label "Process yield"       ;
    rdfs:comment "Process yield [%]" ;           
    rdfs:domain jlw:LabSample        ;
    rdfs:range  xsd:double           .

jlw:has_stock_quantity a rdf:Property ;              
