# -------------------------------------------------- #
# LOTUS
# -------------------------------------------------- #

jlw:LotusEntry a rdfs:Class ;
	rdfs:label "LOTUS entry" ;
	rdfs:comment "An entry with organism-chemical-citation from LOTUS " .

jlw:lotus_reports_chemical a rdf:Property ;
	rdfs:label "LOTUS reports chemical" ;
	rdfs:domain jlw:LotusEntry     ;
	rdfs:range  jlw:ChemicalEntity .
	
jlw:lotus_reports_citation a rdf:Property;
	rdfs:label "LOTUS reports citation"  ;
	rdfs:domain jlw:LotusEntry           ;
	rdfs:range  jlw:WikidataCitationXRef .

jlw:lotus_reports_taxon  a rdf:Property;
	rdfs:label "LOTUS reports taxon" ;
	rdfs:domain jlw:LotusEntry       ;
	rdfs:range  jlw:OttTaxon         .

# -------------------------------------------------- #
# MZMINE
# -------------------------------------------------- #

jlw:MZmineChromatogram a rdfs:Class ;
	rdfs:label   "MZMine chromatogram"                      ;
    rdfs:comment "A chromatogram after alignment by MZMine" .

jlw:MZmineFeature a rdfs:Class ;
    rdfs:label   "A MZMine feature"                     ;
    rdfs:comment "A spectral feature aligned by MZMine" .

jlw:MZMinePeak a  rdfs:Class ;
    rdfs:label   "A MZMine peak" ;
    rdfs:comment  "A chromatogram peak after alignment by MZMine" .

jlw:SinwolfImgXRef a rdfs:Class ;
	rdfs:label   "helper image xref" ;
	rdfs:comment "helper image xref" .

jlw:USIImgXRef a rdfs:Class ;
    rdfs:label    "USI image xref" ;
     rdfs:comment "USI image xref" .

jlw:has_MZmine_chromatogram a rdf:Property ;
	rdfs:label "has MZmine chromatogram" ;
	rdfs:domain jlw:LabSample            ;
    rdfs:range  jlw:MZmineChromatogram   .

jlw:has_MZmine_MZ a rdf:Property ;
    rdfs:label "has MZmine M/Z"   ;
    rdfs:domain jlw:MZmineFeature ;   
	rdfs:range  xsd:double        .

jlw:has_MZmine_RT a rdf:Property ;
    rdfs:label "has MZmine M/Z"   ;
    rdfs:domain jlw:MZmineFeature ;   
    rdfs:range  xsd:double        .

jlw:has_MZmine_feature_STRONG a rdf:Property ;
    rdfs:label "has MZMine strong feature"   ;
	rdfs:domain jlw:MZmineChromatogram       ;
	rdfs:range  jlw:MZMineFeature            .

jlw:has_MZmine_feature_WEAK a rdf:Property ;
    rdfs:label "has MZMine weak feature" ;
	rdfs:comment "Strong and weak sets of features are disjoint" ;
    rdfs:domain jlw:MZmineChromatogram   ;
    rdfs:range  jlw:MZMineFeature        .

jlw:has_MZmine_peak a rdf:Property ;
    rdfs:label "has MZMine strong feature" ;
    rdfs:domain jlw:MZmineChromatogram     ;
    rdfs:range  jlw:MZMinePeak             .

jlw:has_MZMine_area a rdf:Property ;
    rdfs:label "has MZMine strong feature" ;
    rdfs:domain jlw:MZminePeak             ;
	rdfs:range  xsd:double                 .

jlw:has_MZMine_feature a rdf:Property ;
    rdfs:label "has MZMine strong feature" ;
    rdfs:domain jlw:MZminePeak             ;
    rdfs:range  jlw:MZMineFeature          .

# -------------------------------------------------- #
# Assay results
# -------------------------------------------------- #

jlw:AssayResult a rdfs:Class ;
	rdfs:label   "Assay result" ;
	rdfs:comment "Assay result." .
	
jlw:TSAssayResult a rdfs:Class ;
	rdfs:subClassOf jlw:AssayResult          ;
	rdfs:label   "Assay result from TS lab"  ;
	rdfs:comment "Assay result from TS lab." .

jlw:VKAssayResult a rdfs:Class ;
	rdfs:subClassOf jlw:AssayResult          ;
	rdfs:label   "Assay result from VK lab"  ;
	rdfs:comment "Assay result from VK lab." .

jlw:CTAssayResult a rdfs:Class ;
	rdfs:subClassOf jlw:AssayResult          ;
	rdfs:label   "Assay result from CT lab"  ;
	rdfs:comment "Assay result from CT lab." .

jlw:CWAssayResult a rdfs:Class ;
	rdfs:subClassOf jlw:AssayResult          ;
	rdfs:label   "Assay result from CW lab"  ;
	rdfs:comment "Assay result from CW lab." .

jlw:TPHAssayResult a rdfs:Class ;
	rdfs:subClassOf jlw:AssayResult          ;
	rdfs:label   "Assay result from TPH lab"  ;
	rdfs:comment "Assay result from Swiss TPH lab." .

jlw:INVENTAAssayResult a rdfs:Class ;
	rdfs:subClassOf jlw:AssayResult                    ;
	rdfs:label   "Assay result from INVENTA protocol"  ;
	rdfs:comment "Assay result from INVENTA protocol." .

jlw:MEMOAssayResult a rdfs:Class ;
	rdfs:subClassOf jlw:AssayResult                 ;
	rdfs:label   "Assay result from MEMO protocol"  ;
	rdfs:comment "Assay result from MEMO protocol." .

# -------------------------------------------------- #
# has_assay_result properties
# -------------------------------------------------- #

jlw:has_assay_result a rdf:Property ;
    rdfs:label "has assay result" ;
	rdfs:domain        jlw:LabSample        ;
	rdfs:range         jlw:AssayResult   .

jlw:has_bio_assay_result a rdf:Property ;
    rdfs:subPropertyOf jlw:has_assay_result ;
    rdfs:label "has bio assay result" ;
	rdfs:domain        jlw:LabSample        ;
	rdfs:range         jlw:AssayResult   .

jlw:has_chemo_assay_result a rdf:Property ;
    rdfs:subPropertyOf jlw:has_assay_result ;
    rdfs:label "has chemo assay result" ;
	rdfs:domain        jlw:LabSample        ;
	rdfs:range         jlw:AssayResult   .

jlw:has_insilico_assay_result a rdf:Property ;
    rdfs:subPropertyOf jlw:has_assay_result  ;
    rdfs:label "has in-silico assay result"  ;
	rdfs:domain        jlw:LabSample        ;
	rdfs:range         jlw:AssayResult   .

jlw:has_CW_bio_assay_result a rdf:Property ;
    rdfs:subPropertyOf jlw:has_bio_assay_result    ;
    rdfs:label "has CW bio assay result"           ;
	rdfs:domain        jlw:LabSample        ;
	rdfs:range         jlw:CWAssayResult .
	
jlw:has_TS_bio_assay_result a rdf:Property ;
    rdfs:subPropertyOf jlw:has_bio_assay_result    ;
    rdfs:label "has TS bio assay result"           ;
	rdfs:domain        jlw:LabSample        ;
	rdfs:range         jlw:TSAssayResult .

jlw:has_VK_bio_assay_result a rdf:Property ;
    rdfs:subPropertyOf jlw:has_bio_assay_result    ;
    rdfs:label "has VK bio assay result"           ;
	rdfs:domain        jlw:LabSample        ;
	rdfs:range         jlw:VKAssayResult .

jlw:has_CT_bio_assay_result a rdf:Property ;
    rdfs:subPropertyOf jlw:has_bio_assay_result    ;
    rdfs:label "has CT bio assay result"           ;
	rdfs:domain        jlw:LabSample        ;
	rdfs:range         jlw:OHAssayResult .

jlw:has_INVENTA_insilico_assay_result a rdf:Property          ;
    rdfs:subPropertyOf jlw:has_insilico_assay_result    ;
    rdfs:label "has INVENTA in-silico assay result"     ;
	rdfs:domain        jlw:LabSample             ;
	rdfs:range         jlw:INVENTAAssayResult .

jlw:has_SwissTPH_bioassay_result a rdf:Property     ;
    rdfs:subPropertyOf jlw:has_bio_assay_result ;
    rdfs:label "has TPH bio assay result"            ;	
	rdfs:domain        jlw:LabSample          ;
	rdfs:range         jlw:TPHAssayResult  .

# -------------------------------------------------- #
# Cross-references classes. These are used to qualify 
# documents on external servers.
# -------------------------------------------------- #

jlw:XRef a rdfs:Class ;
    rdfs:label "Cross reference" ;
    rdfs:comment "A cross reference that point to an external resource" .

#jlw:IdXRef rdfs:subClassOf jlw:XRef ;
#    rdfs:label "External identifier" ;
#    rdfs:comment "A RDF identifier on an external server" . 
jlw:ImgXRef a rdfs:Class  ;  
	rdfs:subClassOf jlw:XRef ;
    skos:related foaf:Image ;
    rdf:label "External image" ;
    rdfs:comment "A link to an image on an external server" .

jlw:DocXRef a rdfs:Class  ;  
	rdfs:subClassOf jlw:XRef ;
    rdf:label "External document" ;
    rdfs:comment "A link to a browsable document on an external server (disjoint from jlw:IdXRef and jlw:ImgXRef)" .

jlw:OTTDocXRef a rdfs:Class  ;  
	rdfs:subClassOf jlw:DocXRef ;
    rdfs:label "OTT XRef" ;
    rdfs:comment "A cross reference to an Open Tree of Life identifier" .

jlw:WikidataTaxoXRef a rdfs:Class  ;  
	rdfs:subClassOf jlw:WikidataXRef ;
    rdfs:label "WD taxo xref" ;
    rdfs:comment "A cross reference to a taxon in wikidata" .

jlw:WikidataCitationXRef a rdfs:Class ;  
	rdfs:subClassOf jlw:WikidataXRef ;
    rdfs:label "WD citation xref" ;
    rdfs:comment "A cross reference to a citation in wikidata" .

jlw:USIImgXRef a rdfs:Class  ;  
	rdfs:subClassOf jlw:ImgXRef ;
    rdf:label "Image from metabolomics-usi" ;
    rdfs:comment "An image from metabolomics-usi.ucsd.edu".

jlw:WDImgXRef a rdfs:Class  ;  
	rdfs:subClassOf jlw:ImgXRef ;
    rdf:label "Image from WD" ;
    rdfs:comment "An image from www.wikidata.org" .

jlw:SinwolfImgXRef a rdfs:Class  ;  
	rdfs:subClassOf jlw:ImgXRef ;
    rdf:label "Image from or through sinwolf" ;
    rdfs:comment "An image from www.singergiawolfender.org, directly or as a proxy".

# -------------------------------------------------- #
# Predicates for cross references
# -------------------------------------------------- #

jlw:has_xref a rdf:Property ;
	rdfs:label "has xref"                    ;
	rdfs:comment "has a cross-reference in an external resource" .

jlw:has_ott_xref           a rdf:Property ;
	rdfs:subPropertyOf jlw:has_xref ;
	.
jlw:has_exact_ott_xref     a rdf:Property ;
	rdfs:subPropertyOf jlw:has_ott_xref , skos:exactMatch .
jlw:has_broad_ott_xref     a rdf:Property ;
	rdfs:subPropertyOf jlw:has_ott_xref , skos:broadMatch .
jlw:has_narrow_ott_xref    a rdf:Property ;
	rdfs:subPropertyOf jlw:has_ott_xref , skos:narrowMatch .

jlw:has_wd_xref           a rdf:Property ;
	rdfs:subPropertyOf jlw:has_xref             ;
	rdfs:label "has WD xref"                    ;
	rdfs:comment "has WikiData cross-reference" .

jlw:has_wd_chem_xref  a rdf:Property ;
	rdfs:subPropertyOf jlw:has_wd_xref                   ;
	rdfs:label "has WD chem xref"                        ;
	rdfs:comment "has WikiData chemical cross-reference" ;
	rdfs:domain jlw:ChemicalEntity                       .

jlw:has_doc_xref a rdf:Property ;
	rdfs:subPropertyOf jlw:has_xref ;
	rdfs:label "has doc xref"                        ;
	rdfs:comment "has doc xref" .

jlw:usedProtocol a rdf:Property ;
	rdfs:subPropertyOf prov:used ;
	rdfs:label "protocol used by assay batch" ; 
	rdfs:comment "protocol used by assay batch" ;
	rdfs:domain jlw:AssayBatch ; 
	rdfs:range jlw:Protocol .

jlw:usedArticle a rdf:Property ;
	rdfs:subPropertyOf prov:used ;
	rdfs:label "article used by assay batch" ;
	rdfs:comment "article used by assay batch" ;
	rdfs:domain jlw:AssayBatch ; 
	rdfs:range jlw:Article .

jlw:has_operator a rdf:Property ;
	rdfs:subPropertyOf prov:wasAttributedTo ;
	rdfs:label "operator of an assay batch" ;
	rdfs:comment "operator of an assay batch" ;
	rdfs:domain jlw:AssayBatch ; 
	rdfs:range foaf:Person . # should we switch to prov:agent ?

jlw:has_author a rdf:Property ;
	rdfs:subPropertyOf prov:wasAttributedTo ;
	rdfs:label "protocol or article written by operator" ;
	rdfs:comment "protocol or article written by operator" ;
	rdfs:domain jlw:Protocol, jlw:Article ; 
	rdfs:range foaf:Person . # should we switch to prov:agent ?

