#    rdfs:comment "A pair of lab sample" .

# -------------------------------------------------- #
# A collection of samples
# -------------------------------------------------- #

# jlw:SampleCollection a rdfs:Class ;
#    rdfs:subClassOf skos:Collection ;
#	rdfs:label "A collection of samples" ;
#	rdfs:comment "A set of experimental samples that were grouped together because they participate to the same experiment." ;
#    skos:example jlw:chemo_diverse_sample_collection .

jlw:is_part_of_experiment a rdf:Property ;
    rdfs:subPropertyOf skos:members;
    rdfs:label "is part of experiment" ;
    rdfs:comment "Lab samples are grouped into one or several experiments." ;
    rdfs:domain jlw:LabExtract ;
    rdfs:range jlw:SampleCollection .

# -------------------------------------------------- #
# A collection of PF codes
# -------------------------------------------------- #

# jlw:is_part_of_collection a rdf:Property ;
#     rdfs:subPropertyOf skos:members;
#     rdfs:label "is part of PF code collection" ;
#     rdfs:comment "PFCodes are grouped into one or several collections." ;
#     rdfs:domain jlw:PFCode ;
#     rdfs:range skos:Collection .

jlw:is_part_of_PFcode_collection a rdf:Property ;
    rdfs:subPropertyOf skos:members;
    rdfs:label "is part of PF code collection" ;
    rdfs:comment "PFCodes are grouped into one or several collections." ;
    rdfs:domain jlw:PFCode ;
    rdfs:range jlw:PFCodeCollection .

# -------------------------------------------------- #
# A collection of PFcodes
# -------------------------------------------------- #

jlw:PFCodeCollection a rdfs:Class ;
    rdfs:subClassOf skos:Collection ;
	rdfs:label "Collection of PF codes" ;
	rdfs:comment "A set of PF codes that were grouped together because they participate to the same analysis." ;
    skos:example jlw:chemo_diverse_PFcode_collection .
	
# -------------------------------------------------- #
# Object  properties
# -------------------------------------------------- #

jlw:has_lab_process a jlw:LabProcess ; # FIXME
	rdfs:label "has lab process" ;
	rdfs:comment "has any lab process, which could be specified as a sub-property." ;
    rdfs:domain jlw:LabSample ;
    rdfs:range  jlw:LabSample .
	
jlw:has_wikidata_taxo_xref a rdf:property ;
	rdfs:label  "has wikidata taxo xref"  ;
	rdfs:domain jlw:OttTaxon         ;
	rdfs:range  jlw:WikidataTaxoXRef .

# -------------------------------------------------- #
# Data properties
# -------------------------------------------------- #
	
jlw:has_stock_quantity a rdf:property ;
	rdfs:label  "has stock quantity" ;
	rdfs:domain jlw:LabSample;
	rdfs:range  xsd:double .
	
jlw:lab_book_initals a rdf:property ;
	rdfs:label  "has lab book initals" ;
	rdfs:domain jlw:LabSample ;
	rdfs:range  xsd:string    .

jlw:has_rank a rdf:property ;
	rdfs:label  "has rank" ;
	rdfs:domain jlw:PlantPart ;
	rdfs:range  xsd:string    .

jlw:has_tube_quantity a rdf:property ;
	rdfs:label  "has tube quantity" ;
	rdfs:domain jlw:LabSample ;
	rdfs:range  xsd:double.

jlw:is_part_of_selection_round a rdf:property ;
	rdfs:label  "is part of selection round" ;
	rdfs:domain jlw:LabExtract ;
	rdfs:range  xsd:string     .

jlw:has_operator a rdf:property ;
	rdfs:label  "has operator" ;
	rdfs:domain jlw:LabSample  ;
	rdfs:range  xsd:string     .
	
jlw:has_process_type a rdf:property ;
	rdfs:label  "has process type" ;
	rdfs:domain jlw:LabSample ;
	rdfs:range  xsd:string    .

jlw:has_solvent a rdf:property ;
	rdfs:label  "has solvent" ;
	rdfs:domain jlw:LabSample ;
	rdfs:range  xsd:string    .
	
jlw:has_in_cellulo_exp_id a rdf:property ;
	rdfs:label  "has in cellulo_exp_id" ;
	rdfs:domain jlw:TSAssayResult    ;
	rdfs:range  xsd:string              .
	
jlw:has_in_vitro_exp_id a rdf:property ;
	rdfs:label  "has in vitro exp id" ;
	rdfs:domain jlw:TSAssayResult  ;
	rdfs:range  xsd:string            .
	
jlw:has_putative_interpretation a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has putative interpretation" ;
	rdfs:domain jlw:TSAssayResult          ;
	rdfs:range  xsd:string                    .

jlw:has_remaining_growth_dd_in_infection a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has remaining growth dd in infection" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:double                           .

jlw:has_remaining_growth_dd_in_infection_sd a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has remaining growth dd in infection sd" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:double                           .

jlw:has_remaining_growth_mm_in_broth a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has remaining growth mm in broth" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:double                           .

jlw:has_remaining_growth_mm_in_broth_sd a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has remaining growth mm in broth sd" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:double                           .

jlw:has_remaining_growth_mm_in_infection a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has remaining growth mm in infection" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:double                           .

jlw:has_remaining_growth_mm_in_infection_sd a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has remaining growth mm in infection sd" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:double                           .

jlw:has_TPH_L_donovani_10ug_ml a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has TPH L donovani 10 ug/nl" ;
	rdfs:domain jlw:TPHAssayResult                 ;
	rdfs:range  xsd:decimal                        .

jlw:has_Wnt_cytotoxic_effect a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "Has Wnt cytotoxic effect" ;
	rdfs:domain jlw:CTAssayResult                 ;
	rdfs:range  xsd:decimal                           .

jlw:has_Dd_in_infection_IC50 a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "Has Dd IC50" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:decimal                           .

jlw:has_Mm_in_infection_IC50 a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "Has Mm IC50 in infection" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:decimal                           .

jlw:has_Mm_in_broth_IC50 a rdf:property ;
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "Has Mm IC50 in broth" ;
	rdfs:domain jlw:TSAssayResult                 ;
	rdfs:range  xsd:decimal                           .

jlw:has_RSV_effect a rdf:Property ; #active, non-active
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has RSV Inhibitory effect"                      ;
	rdfs:comment "Percentage of infected cells in reference to the control on A549 cells, 50 ug ml extract "	;
	rdfs:domain jlw:CTAssayResult    ;
	rdfs:range  xsd:double              .

jlw:has_RSV_effect_cat a rdf:Property ; #active, non-active
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has RSV Inhibitory effect"                      ;
	rdfs:comment "Percentage of infected cells in reference to the control on A549 cells, 50 ug ml extract "	;
	rdfs:domain jlw:CTAssayResult    ;
	rdfs:range  xsd:string              .

jlw:has_RSV_cytotoxic_effect_cat a rdf:Property ; # toxic, non-toxic
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has RSV Cytotoxicity on A549 cells"                      ;
	rdfs:comment "Resazurine Percentage of cell viability in reference to the control on A549 cells, 50 ug ml extract "	;  
	rdfs:domain jlw:CTAssayResult    ;
	rdfs:range  xsd:string .   

jlw:has_RSV_cytotoxic_effect a rdf:Property ; 
	rdfs:subPropertyOf jlw:has_RSV_effect	 ;
	rdfs:label  "has RSV Cytotoxicity on A549 cells"                      ;
	rdfs:comment "Resazurine Percentage of cell viability in reference to the control on A549 cells, 50 ug ml extract "	;
	rdfs:domain jlw:CTAssayResult    ;
	rdfs:range  xsd:double            .

jlw:has_RSV_toxicity a rdf:Property ; 
	rdfs:subPropertyOf jlw:has_RSV_effect	 ;
	rdfs:label  "has RSV toxicity"                      ;
	rdfs:comment ""	; # Luis please comment
	rdfs:domain jlw:CTAssayResult    ;
	rdfs:range  xsd:double            .

jlw:has_Wnt_effect_cat a rdf:Property ; #active, non-active
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has Wnt Activatory effect"                      ;
	rdfs:comment "IC50 Wnt regulation on BT-20 TNBC"	;
	rdfs:domain jlw:VKAssayResult    ;
	rdfs:range  xsd:string              .

jlw:has_Wnt_effect a rdf:Property ; 
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has Wnt Activatory effect"                      ;
	rdfs:comment "IC50 Wnt regulation on BT-20 TNBC"	;
	rdfs:domain jlw:VKAssayResult    ;
	rdfs:range  xsd:double              .

jlw:has_Wnt_activatory_effect a rdf:Property ;
	rdfs:subPropertyOf jlw:has_Wnt_effect    ;
	rdfs:label  "has Wnt Activatory effect"                      ;
	rdfs:comment "IC50 Wnt activation on BT-20 TNBC"	;
	rdfs:domain jlw:VKAssayResult    ;
	rdfs:range  xsd:double              .

jlw:has_Wnt_inhibitory_effect a rdf:Property ;
	rdfs:subPropertyOf jlw:has_Wnt_effect	 ;
	rdfs:label  "has Wnt Inhibitory effect"                      ;
	rdfs:comment "IC50 Wnt inhibition on BT-20 TNBC"	;
	rdfs:domain jlw:VKAssayResult    ;
	rdfs:range  xsd:double              .

jlw:has_Wnt_upstream_inhibitory_effect a rdf:Property ;
	rdfs:subPropertyOf jlw:has_Wnt_inhibitory_effect	 ;
	rdfs:label  "has Wnt Inhibitory upstream-regulated effect"                      ;
	rdfs:comment "IC50 Wnt upstream inhibition on BT-20 TNBC"	;
	rdfs:domain jlw:VKAssayResult    ;
	rdfs:range  xsd:double              .

jlw:has_Wnt_downstream_inhibitory_effect a rdf:Property ;
	rdfs:subPropertyOf jlw:has_Wnt_inhibitory_effect	 ;
	rdfs:label  "has Wnt Inhibitory downstream-regulated effect"                      ;
	rdfs:comment "IC50 Wnt downstream inhibition on BT-20 TNBC"	;
	rdfs:domain jlw:VKAssayResult    ;
	rdfs:range  xsd:double              .

jlw:has_Wnt_cytotoxic_effect_cat a rdf:Property ; # toxic, non-toxic
	rdfs:subPropertyOf jlw:has_assay_result_value	 ;
	rdfs:label  "has Wnt Cytotoxicity"                      ;
	rdfs:comment "MTT IC50 of BT-20 TNBC cell viability"	;
	rdfs:domain jlw:VKAssayResult    ;
	rdfs:range  xsd:string .   

jlw:has_Wnt_cytotoxic_effect a rdf:Property ;
	rdfs:subPropertyOf jlw:has_Wnt_cytotoxic_effect	 ;
	rdfs:label  "has a Wnt Cytotoxicity"                      ;
	rdfs:comment "MTT IC50 of BT-20 TNBC cell viability"	;
	rdfs:domain jlw:VKAssayResult    ;
	rdfs:range  xsd:double            .

