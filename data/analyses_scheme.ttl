@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>   .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#>         .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#>          .
@prefix owl:     <http://www.w3.org/2002/07/owl#>                .
@prefix doi:     <https://doi.org/>                               .
@prefix pmid:    <http://rdf.ncbi.nlm.nih.gov/pubmed/>           .      
@prefix jlw:     <https://www.sinergiawolfender.org/jlw/>        .
@prefix prov:    <http://www.w3.org/ns/prov#/>        .
@prefix xsd:  	 <http://www.w3.org/2001/XMLSchema#>.
@prefix dcat:    <http://www.w3.org/ns/dcat#>                  .
@prefix dcterms: <http://purl.org/dc/terms/> .

# bio batches

jlw:AssayBatch a owl:Class  ; # TODO change all rdfs:Class to owl:Class. All owl:Class are rdfs:Class, but not the other way around!
	rdfs:subClassOf skos:Collection, prov:Activity ;
	skos:members jlw:AllAssayBatch ;
	rdfs:label "Assay batch of results"       ; 
	rdfs:comment "A collection of analyses acquired at the same time and at the same place under the same protocol. It might also be called an analytical batch." .

