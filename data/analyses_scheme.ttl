#######################################################################
# Protocols
#######################################################################

# jlw:usedProtocol and jlw:usedArticle defined in schema.ttl
# jlw:has_operator and jlw:has_author defined as a subPropertyoOf prov:wasAttributedTo in 

jlw:Protocol a owl:Class ;
	rdfs:subClassOf prov:Entity ;
    rdfs:label              "Protocol used in sinergiawolfender"    ;
    rdfs:comment            "Protocol used in sinergiawolfender"    .

jlw:TSProtocol_20230801 a jlw:Protocol ; # QUESTION: should we simplify and have the url as ID?
    rdfs:label              "Screening protocol"    ;
    rdfs:comment            "Lab operations for an infection and broth bioassay"    ;
	prov:generatedAtTime "2023-08-01"^^xsd:date ;
	jlw:has_author jlw:Jahn_Nitschke ; # Possibly add Thierry and Nabil
	rdfs:seeAlso "https://www.sinergiawolfender.org/protected/jlw/protocols/20230801JN_Infection_in_broth_protocol.docx"^^xsd:anyURI .
	# What other properties?

jlw:TS_thesis_JNitschke a jlw:Protocol ; # QUESTION: should we simplify and have the url as ID?
    # rdfs:label              "Screening protocol"    ;
    # rdfs:comment            "Lab operations for an infection and broth bioassay"    ;
	# prov:generatedAtTime "2023-08-01"^^xsd:date ;
	jlw:has_author jlw:Jahn_Nitschke ; 
	rdfs:seeAlso "https://www.sinergiawolfender.org/protected/jlw/data/20240422_NitschkeJahn_PhD_thesis.pdf"^^xsd:anyURI .
	# What other properties?

jlw:CWProtocol_2022 a jlw:Protocol ;
    rdfs:label              "Protocol for CW assays"    ;
    rdfs:comment            "Protocol for CW assays"    ;
	prov:generatedAtTime "2022-01-01"^^xsd:date ;
	jlw:has_author jlw:Chunyan_Wu ; 
	rdfs:seeAlso "https://www.sinergiawolfender.org/protected/jlw/data/Autophagy_LD_staining_method_Wolfrum_lab.docx"^^xsd:anyURI .

jlw:TPHProtocol_2022XXXX a jlw:Protocol ;
    rdfs:label              "TPH protocol"    ;
    rdfs:comment            "TPH protocol"    ;
	prov:generatedAtTime "2022-01-01"^^xsd:date ;
	jlw:has_author "TODO add who" ;
